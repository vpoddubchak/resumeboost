// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// Users table for user management
model User {
  user_id        Int       @id @default(autoincrement())
  email          String    @unique
  password_hash  String?   @db.VarChar(255)
  first_name     String?   @db.VarChar(100)
  last_name      String?   @db.VarChar(100)
  role           String    @default("job_seeker") @db.VarChar(20)
  email_verified DateTime?
  image          String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  // Relations
  uploads       Upload[]
  analyses      Analysis[]
  consultations Consultation[]
  analytics     Analytics[]
  accounts      Account[]

  @@map("users")
}

// Account model for NextAuth.js OAuth providers
model Account {
  id                 String  @id @default(cuid())
  user_id            Int
  type               String
  provider           String
  provider_account_id String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([provider, provider_account_id])
  @@index([user_id])
  @@map("accounts")
}

// VerificationToken model for email verification
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Uploads table for resume files
model Upload {
  upload_id     Int      @id @default(autoincrement())
  user_id       Int
  file_name     String   @db.VarChar(255)
  file_path     String   @db.VarChar(500)
  file_size     Int
  mime_type     String   @db.VarChar(100)
  upload_status String   @default("uploaded") @db.VarChar(50)
  created_at    DateTime @default(now())

  // Relations
  user    User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  analyses Analysis[]

  @@map("uploads")
  @@index([user_id])
  @@index([created_at])
}

// Analyses table for AI results
model Analysis {
  analysis_id      Int      @id @default(autoincrement())
  upload_id        Int
  user_id          Int
  analysis_data    Json
  score            Int?
  recommendations Json?
  created_at       DateTime @default(now())

  // Relations
  upload Upload @relation(fields: [upload_id], references: [upload_id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("analyses")
}

// Consultations table for booking
model Consultation {
  consultation_id   Int      @id @default(autoincrement())
  user_id           Int
  consultation_date DateTime
  duration_minutes  Int      @default(30)
  status            String   @default("scheduled") @db.VarChar(50)
  notes             String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  // Relations
  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("consultations")
}

// Availability rules for consultant scheduling
model AvailabilityRule {
  rule_id     Int      @id @default(autoincrement())
  day_of_week Int      // 0=Sunday, 1=Monday, ..., 6=Saturday
  start_time  String   // "09:00" (HH:mm in consultant's timezone)
  end_time    String   // "18:00"
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([day_of_week, start_time])
  @@map("availability_rules")
}

// Date overrides for blocking or customizing specific dates
model DateOverride {
  override_id Int      @id @default(autoincrement())
  date        DateTime @db.Date
  is_blocked  Boolean  @default(true) // true=day off, false=custom hours
  start_time  String?  // custom hours if is_blocked=false
  end_time    String?
  reason      String?  @db.VarChar(255)
  created_at  DateTime @default(now())

  @@unique([date])
  @@map("date_overrides")
}

// Portfolio_content table for examples
model PortfolioContent {
  content_id  Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?
  content_type String  @db.VarChar(50)
  file_url    String?  @db.VarChar(500)
  is_featured Boolean  @default(false)
  created_at  DateTime @default(now())

  @@map("portfolio_content")
}

// Success stories table for testimonials and case studies
model SuccessStory {
  story_id          Int      @id @default(autoincrement())
  client_name       String   @db.VarChar(100)
  client_role       String?  @db.VarChar(100)
  industry          String   @db.VarChar(50)
  challenge         String   // TEXT — before-state problem description
  solution          String   // TEXT — what ResumeBoost did
  results           String   // TEXT — measurable outcomes narrative
  testimonial_quote String?  // TEXT — client quote
  outcome_type      String   @db.VarChar(50) // e.g., "career-change", "salary-increase"
  metrics           Json?    // Structured: { salaryIncrease: "25%", interviewsSecured: 5 }
  is_featured       Boolean  @default(false)
  created_at        DateTime @default(now())

  @@index([industry])
  @@index([outcome_type])
  @@map("success_stories")
}

// Analytics table for tracking
model Analytics {
  analytics_id Int      @id @default(autoincrement())
  user_id     Int
  event_type  String   @db.VarChar(100)
  event_data  Json?
  created_at  DateTime @default(now())

  // Relations
  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("analytics")
  @@index([user_id])
  @@index([created_at])
  @@index([event_type])
}
